# ─── Discord Bot Credentials ──────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications

# Your bot's secret token (never share this!)
BOT_TOKEN=your_bot_token_here

# Your bot's Application ID (found on the General Information page)
CLIENT_ID=your_client_id_here

# ─── Web Dashboard ────────────────────────────────────────────────────────────
# Port for the Express dashboard (default: 3000)
DASHBOARD_PORT=3000
